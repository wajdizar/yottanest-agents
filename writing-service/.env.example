# Writing Service Environment Variables

# Required - OpenRouter API key
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model Configuration (optional - defaults shown)
LLM_MODEL_HEAVY=anthropic/claude-sonnet-4
LLM_MODEL_STANDARD=anthropic/claude-sonnet-4
LLM_MODEL_LIGHT=anthropic/claude-haiku

# Timeouts in seconds (optional - defaults shown)
WRITE_TIMEOUT_SECONDS=600
SECTION_TIMEOUT_SECONDS=120
LLM_CALL_TIMEOUT_SECONDS=60

# Retry Configuration (optional - defaults shown)
SECTION_CHECKER_MAX_RETRIES=2
RETRIEVAL_MAX_ITERATIONS=3

# Logging (optional - defaults shown)
LOG_LEVEL=INFO
LOG_FORMAT=json

# Server (optional - defaults shown)
HOST=0.0.0.0
PORT=8500
